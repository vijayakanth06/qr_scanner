{
  "rules": {
    ".read": false,
    ".write": false,
    "studentsByRoll": {
      ".read": true,
      "$rollNo": {
        ".read": true,
        ".write": true
      }
    },
    "hierarchy": {
      ".read": "auth != null && auth.token.admin === true",
      "$branch": {
        "$year": {
          "$section": {
            "$rollNo": {
              ".write": "auth != null && auth.token.admin === true",
              ".validate": "newData.isBoolean() || newData.val() === null"
            }
          }
        }
      }
    },
    "audit": {
      ".read": "auth != null && auth.token.admin === true",
      "studentMutations": {
        "$entryId": {
          ".write": "auth != null && auth.token.admin === true && !data.exists() && newData.exists()",
          ".validate": "newData.hasChildren(['action','rollNo','actorUid','actorEmail','timestamp','before','after'])",
          "action": {
            ".validate": "newData.isString() && (newData.val() === 'create' || newData.val() === 'update' || newData.val() === 'delete')"
          },
          "rollNo": {
            ".validate": "newData.isString() && newData.val().matches(/^[0-9]{2}[A-Z]{2,4}[0-9]{3}$/)"
          },
          "actorUid": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "actorEmail": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          },
          "before": {
            ".validate": "newData.val() === null || newData.hasChildren()"
          },
          "after": {
            ".validate": "newData.val() === null || newData.hasChildren()"
          },
          "$other": {
            ".validate": "newData.val() === null || $other === 'sourceRoll' || $other === 'sourcePath'"
          }
        }
      }
    }
  }
}
